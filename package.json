{
  "name": "zaphnath",
  "description": "Zaphnath Bible Reader - A modern, secure Bible study application",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "author": {
    "email": "beabzk@proton.me",
    "name": "Beabfekad Zikie",
    "url": "https://beabzk.github.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beabzk/zaphnath.git"
  },
  "homepage": "https://beabzk.github.io/zaphnath",
  "bugs": {
    "url": "https://github.com/beabzk/zaphnath/issues"
  },
  "main": "packages/entry-point.mjs",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter @app/* --if-present run build",
    "compile": "pnpm run build && electron-builder build --config electron-builder.mjs",
    "start": "node packages/dev-mode.js",
    "typecheck": "pnpm -r --filter @app/* --if-present run typecheck",
    "create-renderer": "pnpm create vite@latest packages/renderer",
    "integrate-renderer": "pnpm --filter @app/integrate-renderer start",
    "init": "pnpm run create-renderer && pnpm run integrate-renderer && pnpm install",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "convert-bible-files": "bash tools/convert-bible-files.sh",
    "validate-zbrs": "node tools/validators/validate-zbrs.js",
    "test-import": "node tools/test-import.js",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "version:prerelease": "pnpm version prerelease",
    "version:show": "node -p \"require('./package.json').version\"",
    "version:info": "node tools/version-manager.js show",
    "version:set": "node tools/version-manager.js set",
    "version:tag": "node tools/version-manager.js tag",
    "version:help": "node tools/version-manager.js help",
    "zbrs:version:show": "node tools/zbrs-version-manager.js show",
    "zbrs:version:set": "node tools/zbrs-version-manager.js set",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,html,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,html,md,yml,yaml}\""
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.3",
    "@npmcli/map-workspaces": "5.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "13.0.6",
    "prettier": "^3.8.1",
    "vite": "^7.1.11"
  },
  "dependencies": {
    "@app/main": "workspace:*",
    "@app/preload": "workspace:*",
    "@app/renderer": "workspace:*",
    "@radix-ui/react-dropdown-menu": "^2.1.16"
  }
}
