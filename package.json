{
  "name": "zaphnath",
  "version": "0.1.2",
  "description": "a simple electron app that is a Bible",
  "main": "src/app.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.beabzk.zaphnath",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.2.1",
    "electron-builder": "^24.9.1"
  },
  "license": "ISC",
  "author": "beabzk"
}
